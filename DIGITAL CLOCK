import time 
import sys
hour=3
minutes=0
seconds=0
while True:
    sys.stdout.write("\r{:02d}:{:02d}.{:02d}".format(hour,minutes,seconds))
    sys.stdout.flush()
    time.sleep(1)
    seconds=seconds+1
    if seconds==60:
        minutes=minutes+1
    if minutes==60:
        hour=hour+1
    if hour==13:
        hour=0
        minutes=0
        seconds=0
